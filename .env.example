# ──────────────────────────────────────────────
# Application Expo (variables publiques)
# ──────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
EXPO_PUBLIC_KKIAPAY_API_KEY=your_kkiapay_public_key
EXPO_PUBLIC_KKIAPAY_SANDBOX=true

# ──────────────────────────────────────────────
# Supabase Edge Functions (secrets côté serveur)
# Injectés via : supabase secrets set NOM=valeur
# NE PAS mettre dans .env (fichier serveur uniquement)
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
KKIAPAY_PUBLIC_KEY=your_kkiapay_public_key
KKIAPAY_PRIVATE_KEY=your_kkiapay_private_key
KKIAPAY_SANDBOX=true
