{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "routes": [
    {
      "src": "^/(_expo|assets|favicon\\.png)(/.*)?$",
      "dest": "/$0"
    },
    {
      "src": "^/.*$",
      "dest": "/index.html"
    }
  ]
}
